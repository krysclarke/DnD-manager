<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DnDManager.ViewModels"
             x:Class="DnDManager.Views.ImportOptionsDialog"
             x:DataType="vm:EncounterTrackerViewModel">

    <StackPanel Spacing="12" MinWidth="300">
        <TextBlock Text="Import Options" FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" />

        <TextBlock Text="Select what to import:"
                   Opacity="0.8" Margin="0,0,0,4" />

        <CheckBox Content="Characters (append to existing)"
                  IsChecked="{Binding ImportCharacters}" />
        <CheckBox Content="Dice History (append to existing)"
                  IsChecked="{Binding ImportDiceHistory}" />
        <CheckBox Content="Campaign Notes (replace existing)"
                  IsChecked="{Binding ImportCampaignNotes}" />

        <StackPanel Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="Import"
                    Command="{Binding ConfirmImportCommand}" />
            <Button Content="Cancel"
                    Command="{Binding CancelImportCommand}" />
        </StackPanel>
    </StackPanel>
</UserControl>
