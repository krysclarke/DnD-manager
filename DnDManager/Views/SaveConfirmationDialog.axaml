<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DnDManager.ViewModels"
             x:Class="DnDManager.Views.SaveConfirmationDialog"
             x:DataType="vm:EncounterTrackerViewModel">

    <StackPanel Spacing="12" MinWidth="300">
        <TextBlock Text="Unsaved Encounter" FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" />

        <TextBlock Text="Save encounter before closing?"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center" Opacity="0.8" />

        <StackPanel Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button Content="Save"
                    Command="{Binding SaveAndCloseCommand}"
                    CommandParameter="{Binding $parent[Window]}" />
            <Button Content="Don't Save"
                    Command="{Binding CloseWithoutSavingCommand}" />
            <Button Content="Cancel"
                    Command="{Binding CancelCloseCommand}" />
        </StackPanel>
    </StackPanel>
</UserControl>
