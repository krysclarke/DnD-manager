<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DnDManager.ViewModels"
             x:Class="DnDManager.Views.ImportDuplicateDialog"
             x:DataType="vm:ImportDuplicateDialogViewModel">

    <StackPanel Spacing="12" MinWidth="400" MaxWidth="500">
        <TextBlock Text="Duplicate Entries Found" FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" />

        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                   HorizontalAlignment="Center" Opacity="0.8" />

        <Border BorderBrush="{DynamicResource DnDBorderBrush}" BorderThickness="1" CornerRadius="4"
                MaxHeight="200" Padding="4">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding DuplicateNames}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Margin="4,2" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Center">
            <Button Content="Skip Duplicates"
                    Command="{Binding SkipCommand}" />
            <Button Content="Overwrite Duplicates"
                    Command="{Binding OverwriteCommand}" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}" />
        </StackPanel>
    </StackPanel>
</UserControl>
