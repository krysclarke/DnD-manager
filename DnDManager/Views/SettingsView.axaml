<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DnDManager.ViewModels"
             xmlns:models="using:DnDManager.Models"
             xmlns:views="using:DnDManager.Views"
             x:Class="DnDManager.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <LayoutTransformControl x:Name="SettingsScaleContainer">
        <Border Padding="24">
        <StackPanel Spacing="24" HorizontalAlignment="Center">

            <!-- Theme Selection -->
            <StackPanel Spacing="8">
                <TextBlock Text="Theme" FontSize="{DynamicResource DnDHeadingFontSize}" FontWeight="Bold" />
                <ItemsControl ItemsSource="{Binding AvailableThemes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:AppTheme">
                            <Button Tag="{Binding}"
                                    MinWidth="140" MinHeight="80"
                                    Margin="0,0,12,12"
                                    Padding="12,8" CornerRadius="8"
                                    HorizontalContentAlignment="Center">
                                <StackPanel Spacing="6" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="4"
                                                HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold" />
                                        <!-- Custom theme indicator -->
                                        <TextBlock Text="*"
                                                   FontWeight="Bold"
                                                   IsVisible="{Binding !IsBuiltIn}"
                                                   Foreground="{DynamicResource DnDLabelForeground}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="4"
                                                HorizontalAlignment="Center">
                                        <Border Width="16" Height="16" CornerRadius="3">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Surface}" />
                                            </Border.Background>
                                        </Border>
                                        <Border Width="16" Height="16" CornerRadius="3">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Accent}" />
                                            </Border.Background>
                                        </Border>
                                        <Border Width="16" Height="16" CornerRadius="3">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding CodeBlockBg}" />
                                            </Border.Background>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- New Theme / Clone buttons -->
                <StackPanel Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Center">
                    <Button Content="+ New Custom Theme"
                            Command="{Binding ThemeEditor.CreateNewThemeCommand}"
                            Padding="12,6" />
                    <Button Content="Clone Current Theme"
                            Command="{Binding CloneCurrentThemeCommand}"
                            Padding="12,6"
                            IsVisible="{Binding IsBuiltInThemeSelected}" />
                </StackPanel>
            </StackPanel>

            <!-- Theme Editor (visible when editing a custom theme) -->
            <Border IsVisible="{Binding ThemeEditor.IsEditorVisible}"
                    Background="{DynamicResource DnDDialogBg}"
                    CornerRadius="8" Padding="16"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource DnDBorderBrush}">
                <views:ThemeEditorView DataContext="{Binding ThemeEditor}" />
            </Border>

            <Separator />

            <!-- UI Scale -->
            <StackPanel Spacing="8">
                <TextBlock Text="UI Scale" FontSize="{DynamicResource DnDHeadingFontSize}" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center">
                    <Button Content="-" Command="{Binding DecreaseScaleCommand}"
                            MinWidth="36" MinHeight="36"
                            HorizontalContentAlignment="Center" />
                    <Slider Value="{Binding UiScale}"
                            Minimum="0.5" Maximum="2.0"
                            TickFrequency="0.25"
                            IsSnapToTickEnabled="True"
                            MinWidth="250" VerticalAlignment="Center" />
                    <Button Content="+" Command="{Binding IncreaseScaleCommand}"
                            MinWidth="36" MinHeight="36"
                            HorizontalContentAlignment="Center" />
                    <TextBlock Text="{Binding UiScaleDisplay}"
                               FontWeight="SemiBold" FontSize="16"
                               VerticalAlignment="Center" MinWidth="48" />
                </StackPanel>
            </StackPanel>

            <Separator />

            <!-- Web Interface -->
            <StackPanel Spacing="8">
                <TextBlock Text="Web Interface" FontSize="{DynamicResource DnDHeadingFontSize}" FontWeight="Bold" />

                <!-- Enable/Disable Toggle -->
                <CheckBox IsChecked="{Binding IsWebInterfaceEnabled}"
                          Content="Enable Web Interface"
                          FontSize="14" />

                <!-- Web settings (disabled when web interface is off) -->
                <StackPanel Spacing="8" IsEnabled="{Binding IsWebInterfaceEnabled}">

                    <!-- Server URL + QR Code -->
                    <StackPanel Orientation="Horizontal" Spacing="12"
                                VerticalAlignment="Center"
                                IsVisible="{Binding WebServerVm.IsRunning}">
                        <TextBlock Text="{Binding WebServerVm.ServerUrl}"
                                   VerticalAlignment="Center" FontFamily="{DynamicResource DnDMonospaceFont}" />
                        <Button Content="Show QR Code"
                                Command="{Binding WebServerVm.ShowQrCodeCommand}"
                                MinHeight="36" Padding="12,4" />
                    </StackPanel>

                    <!-- Network error -->
                    <TextBlock Text="{Binding WebServerVm.NetworkError}"
                               Foreground="{DynamicResource DnDWarningForeground}"
                               FontWeight="SemiBold" TextWrapping="Wrap"
                               IsVisible="{Binding WebServerVm.NetworkError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                    <!-- QR Code overlay -->
                    <Border IsVisible="{Binding WebServerVm.IsQrCodeVisible}"
                            Background="{DynamicResource DnDDialogBg}"
                            CornerRadius="8" Padding="16"
                            HorizontalAlignment="Center">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <Image Source="{Binding WebServerVm.QrCodeImage}"
                                   MaxWidth="300" MaxHeight="300"
                                   Stretch="Uniform" />
                            <TextBlock Text="{Binding WebServerVm.ServerUrl}"
                                       HorizontalAlignment="Center"
                                       FontFamily="{DynamicResource DnDMonospaceFont}" />
                            <Button Content="Close"
                                    Command="{Binding WebServerVm.HideQrCodeCommand}"
                                    HorizontalAlignment="Center"
                                    MinWidth="80" />
                        </StackPanel>
                    </Border>

                    <!-- Web Theme -->
                    <TextBlock Text="Web Theme" FontSize="14" FontWeight="SemiBold"
                               Margin="0,8,0,0" />
                    <ComboBox ItemsSource="{Binding AvailableThemes}"
                              SelectedItem="{Binding SelectedWebTheme}"
                              MinWidth="200">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:AppTheme">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Web UI Scale -->
                    <TextBlock Text="Web UI Scale" FontSize="14" FontWeight="SemiBold"
                               Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Spacing="12"
                                VerticalAlignment="Center">
                        <Button Content="-" Command="{Binding DecreaseWebScaleCommand}"
                                MinWidth="36" MinHeight="36"
                                HorizontalContentAlignment="Center" />
                        <Slider Value="{Binding WebUiScale}"
                                Minimum="0.5" Maximum="2.0"
                                TickFrequency="0.25"
                                IsSnapToTickEnabled="True"
                                MinWidth="250" VerticalAlignment="Center" />
                        <Button Content="+" Command="{Binding IncreaseWebScaleCommand}"
                                MinWidth="36" MinHeight="36"
                                HorizontalContentAlignment="Center" />
                        <TextBlock Text="{Binding WebUiScaleDisplay}"
                                   FontWeight="SemiBold" FontSize="16"
                                   VerticalAlignment="Center" MinWidth="48" />
                    </StackPanel>

                </StackPanel>
            </StackPanel>

            <!-- Contrast Warning -->
            <TextBlock Text="{Binding ContrastWarning}"
                       Foreground="{DynamicResource DnDWarningForeground}" FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ContrastWarning, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        </StackPanel>
        </Border>
        </LayoutTransformControl>
    </ScrollViewer>
</UserControl>
