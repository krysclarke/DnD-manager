<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DnDManager.ViewModels"
             x:Class="DnDManager.Views.AddInitiativePromptDialog"
             x:DataType="vm:EncounterTrackerViewModel">

    <StackPanel Spacing="12" MinWidth="320">
        <TextBlock FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   TextWrapping="Wrap">
            <Run Text="Enter Initiative for " />
            <Run Text="{Binding PendingInitiativeCharacter.Name}" />
        </TextBlock>

        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto">
            <TextBlock Grid.Column="0"
                       Text="Initiative:"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0" />
            <NumericUpDown Grid.Column="1"
                           Value="{Binding PendingInitiativeValue}"
                           Minimum="1" Maximum="30"
                           FormatString="0"
                           MinWidth="120" />
            <Button Grid.Column="2"
                    Content="Roll"
                    Command="{Binding RollPendingInitiativeCommand}"
                    IsVisible="{Binding PendingIsNpc}"
                    MinWidth="60"
                    Margin="8,0,0,0" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Center"
                    Margin="0,8,0,0">
            <Button Content="Confirm"
                    Command="{Binding ConfirmPendingInitiativeCommand}"
                    MinWidth="100" HorizontalContentAlignment="Center" />
            <Button Content="Cancel"
                    Command="{Binding CancelPendingInitiativeCommand}"
                    MinWidth="100" HorizontalContentAlignment="Center" />
        </StackPanel>
    </StackPanel>
</UserControl>
