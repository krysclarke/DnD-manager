<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DnDManager.ViewModels"
             xmlns:views="using:DnDManager.Views"
             x:Class="DnDManager.Views.DiceRollerView"
             x:DataType="vm:DiceRollerViewModel">

    <DockPanel Margin="0,8,8,8">
        <!-- Input area at top -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBox x:Name="DiceInputBox"
                     Text="{Binding DiceInput}"
                     PlaceholderText="2d6+3, 1d20>, hd20+2"
                     MinWidth="175"
                     VerticalAlignment="Center" />
            <Button Content="Roll"
                    Command="{Binding RollCommand}"
                    VerticalAlignment="Center" />
        </StackPanel>

        <!-- History log -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding History}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:DiceHistoryEntryViewModel">
                        <views:DiceHistoryEntryView DataContext="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
