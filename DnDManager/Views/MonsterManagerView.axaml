<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DnDManager.ViewModels"
             xmlns:models="using:DnDManager.Models"
             xmlns:views="using:DnDManager.Views"
             x:Class="DnDManager.Views.MonsterManagerView"
             x:DataType="vm:MonsterManagerViewModel">

    <Grid RowDefinitions="Auto,*">
        <!-- Row 0: Toolbar -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource DnDBorderBrush}" BorderThickness="0,0,0,1"
                Padding="8,4">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="Bestiary"
                           FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           Text="{Binding EntryCount, StringFormat='({0} entries)'}"
                           VerticalAlignment="Center" Opacity="0.6"
                           Margin="8,0,0,0" />
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                    <Button Content="Import from File"
                            Command="{Binding ImportFromFileCommand}"
                            CommandParameter="{Binding $parent[Window]}" />
                    <Button Content="Import from Open5e"
                            Command="{Binding OpenImportPanelCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row 1: Main content -->
        <Grid Grid.Row="1" ColumnDefinitions="250,Auto,*">

            <!-- Left panel: Monster list -->
            <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="8,8,8,0">
                    <TextBox Grid.Column="0"
                             Watermark="Search monsters..."
                             Text="{Binding SearchText}" />
                    <Button Grid.Column="1" Content="+" Margin="4,0,0,0"
                            ToolTip.Tip="Add Monster"
                            Command="{Binding AddEntryCommand}" />
                </Grid>

                <ListBox Grid.Row="2" Margin="4,4,4,0"
                         ItemsSource="{Binding Entries}"
                         SelectedItem="{Binding SelectedEntry}"
                         SelectionMode="Single">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:BestiaryEntryViewModel">
                            <StackPanel Margin="4,2">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding ChallengeRating, StringFormat='CR {0}'}"
                                               FontSize="11" Opacity="0.7" />
                                    <TextBlock Text="{Binding Type}"
                                               FontSize="11" Opacity="0.7" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4"
                          ResizeDirection="Columns" Background="{DynamicResource DnDBorderBrush}" />

            <!-- Right panel: Detail/edit view -->
            <Grid Grid.Column="2">
                <!-- No selection message -->
                <TextBlock Text="Select a monster or add a new one"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.5"
                           IsVisible="{Binding SelectedEntry, Converter={x:Static ObjectConverters.IsNull}}" />

                <!-- Detail view (read-only) -->
                <ScrollViewer IsVisible="{Binding !IsEditing}"
                              Margin="12">
                    <StackPanel Spacing="8"
                                IsVisible="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).SelectedEntry, Converter={x:Static ObjectConverters.IsNotNull}}"
                                DataContext="{Binding SelectedEntry}">
                        <!-- Header -->
                        <TextBlock Text="{Binding Name}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="{Binding TypeDisplay}" FontStyle="Italic" Opacity="0.8" />
                        <TextBlock Text="{Binding Alignment}" Opacity="0.7" />

                        <Separator />

                        <!-- Core stats -->
                        <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{Binding AcDisplay, StringFormat='AC: {0}'}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding HpDisplay, StringFormat='HP: {0}'}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="2"
                                       Text="{Binding ChallengeRating, StringFormat='CR: {0}'}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="0" Grid.Column="3"
                                       Text="{Binding InitiativeDisplay, StringFormat='Init: {0}'}" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                       Text="{Binding Speed, StringFormat='Speed: {0}'}" Margin="0,4,0,0" />
                        </Grid>

                        <Separator />

                        <!-- Ability scores -->
                        <Grid ColumnDefinitions="*,*,*,*,*,*">
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="STR" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Strength}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="DEX" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Dexterity}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="CON" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Constitution}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                <TextBlock Text="INT" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Intelligence}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <TextBlock Text="WIS" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Wisdom}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="5" HorizontalAlignment="Center">
                                <TextBlock Text="CHA" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Charisma}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <Separator />

                        <!-- Senses & Languages -->
                        <TextBlock Text="{Binding Senses, StringFormat='Senses: {0}'}"
                                   IsVisible="{Binding Senses, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <TextBlock Text="{Binding Languages, StringFormat='Languages: {0}'}"
                                   IsVisible="{Binding Languages, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <!-- Multiattack -->
                        <TextBlock Text="Multiattack" FontWeight="Bold" FontSize="16" Margin="0,8,0,0"
                                   IsVisible="{Binding MultiattackDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <TextBlock Text="{Binding MultiattackDescription}"
                                   TextWrapping="Wrap" Opacity="0.8" Margin="8,0,0,0"
                                   IsVisible="{Binding MultiattackDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <!-- Attacks -->
                        <TextBlock Text="Attacks" FontWeight="Bold" FontSize="16" Margin="0,8,0,0"
                                   IsVisible="{Binding Attacks.Count}" />
                        <ItemsControl ItemsSource="{Binding Attacks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Attack">
                                    <Border Padding="6" Margin="0,2" CornerRadius="4"
                                            Background="{DynamicResource DnDHoverHighlight}">
                                        <StackPanel Spacing="2">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding AttackType}" Opacity="0.6"
                                                           FontSize="11" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding ReachDisplay}" Opacity="0.6"
                                                           FontSize="11" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding AttackDice, StringFormat='Atk: {0}'}"
                                                           Opacity="0.8" />
                                                <TextBlock Text="{Binding TotalAverageDamage, StringFormat='Avg Dmg: {0}'}"
                                                           Opacity="0.8" />
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{Binding DamageEntries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:DamageEntry">
                                                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding DamageDice}" />
                                                            <TextBlock Text="{Binding DamageType}" Opacity="0.7" />
                                                            <TextBlock Text="{Binding AverageDamage, StringFormat='(avg {0})'}"
                                                                       Opacity="0.5" FontSize="11"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding EffectText}"
                                                       FontStyle="Italic" Opacity="0.7"
                                                       TextWrapping="Wrap" Margin="8,2,0,0"
                                                       IsVisible="{Binding EffectText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Special Abilities -->
                        <TextBlock Text="Special Abilities" FontWeight="Bold" FontSize="16" Margin="0,8,0,0"
                                   IsVisible="{Binding HasSpecialAbilities}" />
                        <ItemsControl ItemsSource="{Binding SpecialAbilities}"
                                      IsVisible="{Binding HasSpecialAbilities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:NamedAbility">
                                    <Border Padding="6" Margin="0,2" CornerRadius="4"
                                            Background="{DynamicResource DnDHoverHighlight}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.8" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Non-Attack Actions -->
                        <TextBlock Text="Actions" FontWeight="Bold" FontSize="16" Margin="0,8,0,0"
                                   IsVisible="{Binding HasNonAttackActions}" />
                        <ItemsControl ItemsSource="{Binding NonAttackActions}"
                                      IsVisible="{Binding HasNonAttackActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:NamedAbility">
                                    <Border Padding="6" Margin="0,2" CornerRadius="4"
                                            Background="{DynamicResource DnDHoverHighlight}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.8" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Bonus Actions -->
                        <TextBlock Text="Bonus Actions" FontWeight="Bold" FontSize="16" Margin="0,8,0,0"
                                   IsVisible="{Binding HasBonusActions}" />
                        <ItemsControl ItemsSource="{Binding BonusActions}"
                                      IsVisible="{Binding HasBonusActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:NamedAbility">
                                    <Border Padding="6" Margin="0,2" CornerRadius="4"
                                            Background="{DynamicResource DnDHoverHighlight}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.8" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Reactions -->
                        <TextBlock Text="Reactions" FontWeight="Bold" FontSize="16" Margin="0,8,0,0"
                                   IsVisible="{Binding HasReactions}" />
                        <ItemsControl ItemsSource="{Binding Reactions}"
                                      IsVisible="{Binding HasReactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:NamedAbility">
                                    <Border Padding="6" Margin="0,2" CornerRadius="4"
                                            Background="{DynamicResource DnDHoverHighlight}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.8" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Legendary Actions -->
                        <TextBlock Text="Legendary Actions" FontWeight="Bold" FontSize="16" Margin="0,8,0,0"
                                   IsVisible="{Binding HasLegendaryActions}" />
                        <TextBlock Text="{Binding LegendaryDescription}"
                                   TextWrapping="Wrap" Opacity="0.7" FontStyle="Italic" Margin="8,0,0,4"
                                   IsVisible="{Binding LegendaryDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <ItemsControl ItemsSource="{Binding LegendaryActions}"
                                      IsVisible="{Binding HasLegendaryActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:NamedAbility">
                                    <Border Padding="6" Margin="0,2" CornerRadius="4"
                                            Background="{DynamicResource DnDHoverHighlight}">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.8" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Source -->
                        <TextBlock Text="{Binding Source, StringFormat='Source: {0}'}"
                                   Opacity="0.5" FontSize="11" Margin="0,12,0,0" />

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                            <Button Content="Edit"
                                    Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).EditEntryCommand}" />
                            <Button Content="Delete"
                                    Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).DeleteEntryCommand}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Edit view -->
                <ScrollViewer IsVisible="{Binding IsEditing}"
                              Margin="12">
                    <StackPanel Spacing="8"
                                DataContext="{Binding SelectedEntry}">
                        <TextBlock Text="Edit Monster" FontSize="18" FontWeight="Bold" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              Margin="0,0,0,0">

                            <!-- Name -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Spacing="2">
                                <TextBlock Text="Name" />
                                <TextBox Text="{Binding Name}" />
                            </StackPanel>

                            <!-- Size / Type -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                                <TextBlock Text="Size" />
                                <ComboBox ItemsSource="{Binding AvailableSizes}"
                                          SelectedItem="{Binding Size}"
                                          MinWidth="150" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2" Margin="8,0,0,0">
                                <TextBlock Text="Type" />
                                <TextBox Text="{Binding Type}" />
                            </StackPanel>

                            <!-- Subtype / Alignment -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2">
                                <TextBlock Text="Subtype" />
                                <TextBox Text="{Binding Subtype}" />
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2" Margin="8,0,0,0">
                                <TextBlock Text="Alignment" />
                                <TextBox Text="{Binding Alignment}" />
                            </StackPanel>

                            <!-- AC / AC Desc -->
                            <StackPanel Grid.Row="3" Grid.Column="0" Spacing="2">
                                <TextBlock Text="Armor Class" />
                                <NumericUpDown Value="{Binding ArmorClass}"
                                               Minimum="0" Maximum="30" FormatString="0" />
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="1" Spacing="2" Margin="8,0,0,0">
                                <TextBlock Text="Armor Description" />
                                <TextBox Text="{Binding ArmorDescription}"
                                         Watermark="e.g. leather armor, shield" />
                            </StackPanel>

                            <!-- HP (dice notation + computed average) -->
                            <StackPanel Grid.Row="4" Grid.Column="0" Spacing="2">
                                <TextBlock Text="Hit Points (dice)" />
                                <TextBox Text="{Binding HitDice}" Watermark="e.g. 10d10+10" />
                            </StackPanel>
                            <StackPanel Grid.Row="4" Grid.Column="1" Spacing="2" Margin="8,0,0,0">
                                <TextBlock Text="Average HP" />
                                <TextBlock Text="{Binding AverageHpDisplay}"
                                           FontSize="16" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,6,0,0" />
                            </StackPanel>

                            <!-- CR / Initiative -->
                            <StackPanel Grid.Row="5" Grid.Column="0" Spacing="2">
                                <TextBlock Text="Challenge Rating" />
                                <TextBox Text="{Binding ChallengeRating}" Watermark="e.g. 1/4" />
                            </StackPanel>
                            <StackPanel Grid.Row="5" Grid.Column="1" Spacing="2" Margin="8,0,0,0">
                                <TextBlock Text="Initiative Modifier (blank = DEX mod)" />
                                <TextBox Text="{Binding InitiativeModifierText}" Watermark="e.g. 2" />
                            </StackPanel>

                            <!-- Speed -->
                            <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Spacing="2">
                                <TextBlock Text="Speed" />
                                <TextBox Text="{Binding Speed}" Watermark="e.g. walk 30 ft." />
                            </StackPanel>

                            <!-- Ability Scores -->
                            <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="Ability Scores" FontWeight="SemiBold" Margin="0,8,0,0" />

                            <Grid Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                                  ColumnDefinitions="*,*,*,*,*,*">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="STR" HorizontalAlignment="Center" />
                                    <NumericUpDown Value="{Binding Strength}"
                                                   Minimum="1" Maximum="30" FormatString="0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="DEX" HorizontalAlignment="Center" />
                                    <NumericUpDown Value="{Binding Dexterity}"
                                                   Minimum="1" Maximum="30" FormatString="0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Text="CON" HorizontalAlignment="Center" />
                                    <NumericUpDown Value="{Binding Constitution}"
                                                   Minimum="1" Maximum="30" FormatString="0" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="2">
                                    <TextBlock Text="INT" HorizontalAlignment="Center" />
                                    <NumericUpDown Value="{Binding Intelligence}"
                                                   Minimum="1" Maximum="30" FormatString="0" />
                                </StackPanel>
                                <StackPanel Grid.Column="4" Spacing="2">
                                    <TextBlock Text="WIS" HorizontalAlignment="Center" />
                                    <NumericUpDown Value="{Binding Wisdom}"
                                                   Minimum="1" Maximum="30" FormatString="0" />
                                </StackPanel>
                                <StackPanel Grid.Column="5" Spacing="2">
                                    <TextBlock Text="CHA" HorizontalAlignment="Center" />
                                    <NumericUpDown Value="{Binding Charisma}"
                                                   Minimum="1" Maximum="30" FormatString="0" />
                                </StackPanel>
                            </Grid>

                            <!-- Senses / Languages -->
                            <StackPanel Grid.Row="9" Grid.Column="0" Spacing="2">
                                <TextBlock Text="Senses" />
                                <TextBox Text="{Binding Senses}" />
                            </StackPanel>
                            <StackPanel Grid.Row="9" Grid.Column="1" Spacing="2" Margin="8,0,0,0">
                                <TextBlock Text="Languages" />
                                <TextBox Text="{Binding Languages}" />
                            </StackPanel>
                        </Grid>

                        <!-- Multiattack -->
                        <TextBlock Text="Multiattack" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <TextBox Text="{Binding MultiattackDescription}"
                                 Watermark="e.g. The dragon makes three attacks: one bite and two claws."
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 MinHeight="40" />

                        <!-- Attacks section -->
                        <TextBlock Text="Attacks" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <ItemsControl ItemsSource="{Binding Attacks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:Attack">
                                    <Border Padding="8" Margin="0,4" CornerRadius="4"
                                            BorderBrush="{DynamicResource DnDBorderBrush}" BorderThickness="1">
                                        <StackPanel Spacing="6">
                                            <!-- Row 1: Name + Type + Remove -->
                                            <Grid ColumnDefinitions="*,Auto,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding Name}"
                                                         Watermark="Attack name" />
                                                <ComboBox Grid.Column="1" Margin="8,0,0,0"
                                                          ItemsSource="{x:Static models:Attack.AvailableAttackTypes}"
                                                          SelectedItem="{Binding AttackType}" />
                                                <Button Grid.Column="2" Content="x"
                                                        Padding="6,2" MinWidth="0" Margin="8,0,0,0"
                                                        Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).RemoveAttackCommand}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                            <!-- Row 2: Attack dice + Reach/Range -->
                                            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding AttackDice}"
                                                         Watermark="Attack roll (e.g. d20+4)" />
                                                <!-- Melee: reach -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="8,0,0,0">
                                                    <TextBlock Text="Reach:" VerticalAlignment="Center" />
                                                    <NumericUpDown Value="{Binding Reach}"
                                                                   Minimum="0" Maximum="30"
                                                                   FormatString="0" MinWidth="80" />
                                                    <TextBlock Text="ft." VerticalAlignment="Center" />
                                                </StackPanel>
                                                <!-- Ranged: normal/long -->
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" Margin="8,0,0,0">
                                                    <TextBlock Text="Range:" VerticalAlignment="Center" />
                                                    <NumericUpDown Value="{Binding RangeNormal}"
                                                                   Minimum="0" Maximum="600"
                                                                   FormatString="0" MinWidth="80" />
                                                    <TextBlock Text="/" VerticalAlignment="Center" />
                                                    <NumericUpDown Value="{Binding RangeLong}"
                                                                   Minimum="0" Maximum="600"
                                                                   FormatString="0" MinWidth="80" />
                                                    <TextBlock Text="ft." VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                            <!-- Row 3: Damage entries -->
                                            <TextBlock Text="Damage:" FontSize="12" Opacity="0.7" />
                                            <ItemsControl ItemsSource="{Binding DamageEntries}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:DamageEntry">
                                                        <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,2">
                                                            <TextBox Grid.Column="0" Text="{Binding DamageDice}"
                                                                     Watermark="Dice (e.g. 1d6+2)" />
                                                            <ComboBox Grid.Column="1" Margin="8,0,0,0"
                                                                      ItemsSource="{x:Static models:DamageEntry.AvailableDamageTypes}"
                                                                      SelectedItem="{Binding DamageType}" />
                                                            <Button Grid.Column="2" Content="x"
                                                                    Padding="4,2" MinWidth="0" Margin="4,0,0,0"
                                                                    Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).RemoveDamageEntryCommand}"
                                                                    CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Content="+ Add Damage" FontSize="11"
                                                    HorizontalAlignment="Left" Padding="6,2"
                                                    Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).AddDamageEntryCommand}"
                                                    CommandParameter="{Binding}" />
                                            <!-- Row 4: Effect text -->
                                            <TextBox Text="{Binding EffectText}"
                                                     Watermark="Effect text (e.g. target has Grappled condition, escape DC 13)"
                                                     TextWrapping="Wrap" AcceptsReturn="True"
                                                     MinHeight="40" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Add Attack" HorizontalAlignment="Left"
                                Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).AddAttackCommand}" />

                        <!-- Special Abilities editor -->
                        <TextBlock Text="Special Abilities" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <ItemsControl ItemsSource="{Binding SpecialAbilities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:NamedAbility">
                                    <Border Padding="8" Margin="0,4" CornerRadius="4"
                                            BorderBrush="{DynamicResource DnDBorderBrush}" BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding Name}" Watermark="Ability name" />
                                                <Button Grid.Column="1" Content="x" Padding="6,2" MinWidth="0" Margin="8,0,0,0"
                                                        Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).RemoveSpecialAbilityCommand}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                            <TextBox Text="{Binding Description}" Watermark="Description"
                                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Add Special Ability" HorizontalAlignment="Left"
                                Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).AddSpecialAbilityCommand}" />

                        <!-- Non-Attack Actions editor -->
                        <TextBlock Text="Non-Attack Actions" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <ItemsControl ItemsSource="{Binding NonAttackActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:NamedAbility">
                                    <Border Padding="8" Margin="0,4" CornerRadius="4"
                                            BorderBrush="{DynamicResource DnDBorderBrush}" BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding Name}" Watermark="Action name" />
                                                <Button Grid.Column="1" Content="x" Padding="6,2" MinWidth="0" Margin="8,0,0,0"
                                                        Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).RemoveNonAttackActionCommand}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                            <TextBox Text="{Binding Description}" Watermark="Description"
                                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Add Action" HorizontalAlignment="Left"
                                Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).AddNonAttackActionCommand}" />

                        <!-- Bonus Actions editor -->
                        <TextBlock Text="Bonus Actions" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <ItemsControl ItemsSource="{Binding BonusActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:NamedAbility">
                                    <Border Padding="8" Margin="0,4" CornerRadius="4"
                                            BorderBrush="{DynamicResource DnDBorderBrush}" BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding Name}" Watermark="Bonus action name" />
                                                <Button Grid.Column="1" Content="x" Padding="6,2" MinWidth="0" Margin="8,0,0,0"
                                                        Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).RemoveBonusActionCommand}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                            <TextBox Text="{Binding Description}" Watermark="Description"
                                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Add Bonus Action" HorizontalAlignment="Left"
                                Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).AddBonusActionCommand}" />

                        <!-- Reactions editor -->
                        <TextBlock Text="Reactions" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <ItemsControl ItemsSource="{Binding Reactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:NamedAbility">
                                    <Border Padding="8" Margin="0,4" CornerRadius="4"
                                            BorderBrush="{DynamicResource DnDBorderBrush}" BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding Name}" Watermark="Reaction name" />
                                                <Button Grid.Column="1" Content="x" Padding="6,2" MinWidth="0" Margin="8,0,0,0"
                                                        Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).RemoveReactionCommand}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                            <TextBox Text="{Binding Description}" Watermark="Description"
                                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Add Reaction" HorizontalAlignment="Left"
                                Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).AddReactionCommand}" />

                        <!-- Legendary Actions editor -->
                        <TextBlock Text="Legendary Actions" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <TextBox Text="{Binding LegendaryDescription}"
                                 Watermark="e.g. The dragon can take 3 legendary actions..."
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40" />
                        <ItemsControl ItemsSource="{Binding LegendaryActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:NamedAbility">
                                    <Border Padding="8" Margin="0,4" CornerRadius="4"
                                            BorderBrush="{DynamicResource DnDBorderBrush}" BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBox Grid.Column="0" Text="{Binding Name}" Watermark="Legendary action name" />
                                                <Button Grid.Column="1" Content="x" Padding="6,2" MinWidth="0" Margin="8,0,0,0"
                                                        Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).RemoveLegendaryActionCommand}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                            <TextBox Text="{Binding Description}" Watermark="Description"
                                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Add Legendary Action" HorizontalAlignment="Left"
                                Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).AddLegendaryActionCommand}" />

                        <!-- Save/Cancel -->
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                            <Button Content="Save"
                                    Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).SaveEntryCommand}" />
                            <Button Content="Cancel"
                                    Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).CancelEditCommand}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Import duplicate dialog overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding PendingImportDialogVm, Converter={x:Static ObjectConverters.IsNotNull}}"
                Background="{DynamicResource DnDOverlayBg}">
            <Border Background="{DynamicResource DnDDialogBg}"
                    CornerRadius="8" Padding="16"
                    MaxWidth="500"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BoxShadow="0 4 16 0 #40000000">
                <views:ImportDuplicateDialog DataContext="{Binding PendingImportDialogVm}" />
            </Border>
        </Border>

        <!-- Import overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                IsVisible="{Binding IsImportPanelOpen}"
                Background="{DynamicResource DnDOverlayBg}">
            <Border Background="{DynamicResource DnDDialogBg}"
                    CornerRadius="8" Padding="16"
                    MaxWidth="700" MaxHeight="600"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BoxShadow="0 4 16 0 #40000000">
                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto"
                      DataContext="{Binding ImportVm}">
                    <TextBlock Grid.Row="0" Text="Import from Open5e"
                               FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />

                    <!-- Search bar -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <TextBox Grid.Column="0" Text="{Binding SearchQuery}"
                                 Watermark="Search monsters (e.g. dragon, goblin)..." />
                        <Button Grid.Column="1" Content="Search"
                                Command="{Binding SearchCommand}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <!-- Results list -->
                    <Border Grid.Row="2" BorderBrush="{DynamicResource DnDBorderBrush}" BorderThickness="1" CornerRadius="4">
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding SearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:Open5eMonsterPreview">
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                                              Margin="8,4">
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ChallengeRating, StringFormat='CR {0}'}"
                                                       VerticalAlignment="Center" Opacity="0.7" />
                                            <TextBlock Grid.Column="3" Text="{Binding Type}"
                                                       VerticalAlignment="Center" Opacity="0.7" />
                                            <TextBlock Grid.Column="4" Text="{Binding Source}"
                                                       VerticalAlignment="Center" Opacity="0.5"
                                                       FontSize="11" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Pagination + status -->
                    <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                            <Button Content="Select All" Command="{Binding SelectAllCommand}" />
                            <Button Content="Deselect All" Command="{Binding DeselectAllCommand}" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Opacity="0.7" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                            <Button Content="Prev" Command="{Binding PreviousPageCommand}"
                                    IsEnabled="{Binding HasPreviousPage}" />
                            <Button Content="Next" Command="{Binding NextPageCommand}"
                                    IsEnabled="{Binding HasNextPage}" />
                        </StackPanel>
                    </Grid>

                    <!-- Error + action buttons -->
                    <StackPanel Grid.Row="4" Margin="0,8,0,0" Spacing="4">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource DnDErrorForeground}"
                                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    HorizontalAlignment="Right">
                            <Button Content="Import Selected"
                                    Command="{Binding ImportSelectedCommand}" />
                            <Button Content="Close"
                                    Command="{Binding $parent[UserControl].((vm:MonsterManagerViewModel)DataContext).CloseImportPanelCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
